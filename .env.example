# ==========================================================================
# EaseTrading environment template.
# Copy this file to ".env" and fill in the values. NEVER commit the real .env.
# In "mock" market-feed mode you can leave the Angel One values blank.
# ==========================================================================

# ---- Databases (defaults work with docker-compose) ----
POSTGRES_DB=easetrading
POSTGRES_USER=easetrading
POSTGRES_PASSWORD=change-me-strong-password
# JDBC URL the api service uses to reach Postgres (service name = "postgres")
DB_URL=jdbc:postgresql://postgres:5432/easetrading

REDIS_URL=redis://redis:6379

# ---- Security ----
# Secret used to sign JWT session tokens. Use a long random string in production.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# 32-byte (256-bit) key, base64-encoded, used to encrypt broker credentials at rest.
# Generate one with:  openssl rand -base64 32
CREDENTIAL_AES_KEY=replace-with-base64-encoded-32-byte-key

# ---- Market data feed ----
# "mock" = generated fake ticks (no credentials needed, great for dev)
# "live" = real Angel One SmartAPI WebSocket
MARKET_FEED_MODE=mock

# ---- Angel One SmartAPI (only needed when MARKET_FEED_MODE=live) ----
# These are per-user in production (stored encrypted in the DB). For local single-user
# dev you may seed them here and the api will use them as the default broker session.
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=

# ---- Analysis service ----
# IMPORTANT: do NOT set ANTHROPIC_API_KEY here. The AI layer (Prompt 3) uses the
# Claude Pro plan via the Agent SDK, not the paid API. Setting this key would switch
# billing to pay-as-you-go.
ANALYSIS_SERVICE_URL=http://analysis:8000
# "mock" = fake fundamentals (offline dev). "auto" = real Yahoo + NSE/BSE with fallback.
FUNDAMENTALS_MODE=mock

# ---- Trading (Prompt 4) ----
# "paper" = simulated orders (SAFE default). "live" = real Angel One orders (real money).
TRADING_MODE=paper
# Pre-trade risk limits.
RISK_MAX_ORDER_VALUE=100000
RISK_MAX_POSITION_PCT=25
RISK_DAILY_LOSS_LIMIT=25000
RISK_PRICE_BAND_PCT=10

# ---- Frontend ----
# Base URL the browser uses to reach the api service.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080
